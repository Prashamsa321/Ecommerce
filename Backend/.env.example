# Server
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/merogadget

# Auth
JWT_SECRET=your_secret_key_here

# Default admin (used by npm run seed:admin)
ADMIN_NAME=Admin
ADMIN_EMAIL=admin@merogadget.com
ADMIN_PASSWORD=admin123

# CORS — must match your frontend URL
FRONTEND_URL=http://localhost:3000

# Email — required for real OTP emails in production
# Gmail setup:
#   1. Turn on 2-Step Verification: https://myaccount.google.com/security
#   2. Create App Password: https://myaccount.google.com/apppasswords
#   3. Paste the 16-character app password below (spaces are OK)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_16_char_app_password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
